## Wazuh HIDS - auditd rules
## Mapped to MITRE ATT&CK Linux techniques
## Load: sudo augenrules --load

# Delete all existing rules
-D

# Buffer
-b 8192
-f 1

## ---------- T1059 Command & Scripting Interpreter ----------
-a always,exit -F arch=b64 -S execve -k execve
-a always,exit -F arch=b32 -S execve -k execve

## ---------- T1548 Privilege escalation via sudo/su ----------
-w /usr/bin/sudo -p x -k priv_esc
-w /bin/su      -p x -k priv_esc
-w /etc/sudoers -p wa -k sudoers_change
-w /etc/sudoers.d/ -p wa -k sudoers_change

## ---------- T1136 Account creation ----------
-w /etc/passwd -p wa -k identity
-w /etc/group  -p wa -k identity
-w /etc/shadow -p wa -k identity
-w /etc/gshadow -p wa -k identity

## ---------- T1543.002 SystemD service persistence ----------
-w /etc/systemd/system/ -p wa -k systemd_persist
-w /lib/systemd/system/ -p wa -k systemd_persist
-w /etc/init.d/         -p wa -k init_persist

## ---------- T1053.003 Cron persistence ----------
-w /etc/crontab       -p wa -k cron
-w /etc/cron.d/       -p wa -k cron
-w /etc/cron.hourly/  -p wa -k cron
-w /etc/cron.daily/   -p wa -k cron
-w /etc/cron.weekly/  -p wa -k cron
-w /etc/cron.monthly/ -p wa -k cron
-w /var/spool/cron/   -p wa -k cron

## ---------- T1547 SSH persistence ----------
-w /root/.ssh/           -p wa -k ssh_key
-w /home/                -p wa -k ssh_key_home
-w /etc/ssh/sshd_config  -p wa -k sshd_config

## ---------- T1105 Ingress tool transfer ----------
-a always,exit -F arch=b64 -S connect -F key=network_connect

## ---------- T1005 File collection (sensitive paths) ----------
-w /etc/hostname -p r -k recon
-w /etc/hosts    -p r -k recon

## Make immutable (optional, uncomment for prod)
# -e 2
