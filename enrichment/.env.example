# Copy sang .env và điền giá trị thực. File .env đã trong .gitignore.

# Wazuh Indexer endpoint
# Nếu chạy trên VPS: https://localhost:9200
# Nếu chạy trên Kali (dùng SSH tunnel `ssh -L 9200:localhost:9200 namth@43.228.215.234`):
# WAZUH_INDEXER_URL=https://localhost:9200
WAZUH_INDEXER_URL=https://localhost:9200
WAZUH_INDEXER_USER=admin
WAZUH_INDEXER_PASS=CHANGE_ME
WAZUH_INDEXER_VERIFY_TLS=false

# VirusTotal API v3 — free tier: 4 req/min, 500 req/day
# Get key: https://www.virustotal.com/gui/my-apikey
VT_API_KEY=CHANGE_ME

# AbuseIPDB API v2 — free tier: 1000 req/day
# Get key: https://www.abuseipdb.com/account/api
ABUSEIPDB_API_KEY=CHANGE_ME

# Cache DB (SQLite)
CACHE_DB=enrichment/cache/enrichment.db
# Cache TTL in hours (skip API call nếu < TTL)
CACHE_TTL_HOURS=24
